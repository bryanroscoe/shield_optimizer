{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shield Optimizer",
  "version": "2.0.0-beta.14",
  "identifier": "com.shieldoptimizer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Shield Optimizer",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxMTFEMjVENTI5OEM3QjEKUldTeHg1aFNYZElSY1k0c3B2VmN0SlM1SUw5ZWdoWkVWeXVvR3RmRkNnNDNrWm1NanhOcTNOUjAK",
      "endpoints": [
        "https://raw.githubusercontent.com/bryanroscoe/shield_optimizer/main/v2/updater/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "copyright": "Bryan Roscoe",
    "shortDescription": "Debloat and tune Android TV devices via ADB.",
    "longDescription": "Shield Optimizer is a cross-platform tool for debloating and tuning Nvidia Shield TV, Onn 4K Pro, Chromecast with Google TV, and other Android TV devices. v2 is a Rust/Tauri rewrite of the original PowerShell script.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/scrcpy-server-v3.1"
    ],
    "windows": {
      "wix": {
        "version": "2.0.314"
      }
    }
  }
}
